# PIA Tracker — production environment.
# Copy to /opt/pia/shared/.env on the VM and fill in EVERY value BEFORE the first deploy.
#
# CRITICAL (gotcha #3): postgres roles are created ONLY on first volume init, from the
# *_PASSWORD values below. If these are wrong/empty on the first deploy, the app will
# fail with "password authentication failed" and you must wipe postgres_data to fix it.
#
# CRITICAL (gotcha #10): keep this file ASCII, LF line-endings, no trailing/hidden
# control characters — a stray byte breaks port parsing. `setup.sh` scrubs it, but
# author it clean.

# ── Host ports (crs owns 80/443; PIA publishes its own) ──────────────────────────
PIA_HTTP_PORT=8453
PIA_HTTPS_PORT=8090

# Public base URL the browser uses to reach PIA (for presigned MinIO URLs, Grafana
# sub-path, etc.). Use the host/IP + PIA_HTTP_PORT (or the middleman's URL).
PIA_PUBLIC_BASE_URL=http://REPLACE_WITH_HOST_OR_IP:8453
MINIO_PUBLIC_ENDPOINT=http://REPLACE_WITH_HOST_OR_IP:8453/minio

# ── Backend ──────────────────────────────────────────────────────────────────────
# Keep 'beta' until the real prod auth provider exists (dummy/password/SSO login are
# gated to dev/beta; the 'prod' profile has NO auth endpoints and logins will fail).
PIA_PROFILE=beta
PIA_AUTH_MODE=dummy
PIA_IMAGE_TAG=prod

# Shared HS256 secret for the ABCDE SSO handoff, exchanged securely with the partner
# team out-of-band — never commit the real value anywhere. Leaving this as the
# placeholder means SSO logins will fail signature verification (safe default).
PIA_SSO_SECRET=dev-only-shared-secret-CHANGE-ME

# Max accepted JWT lifetime (exp - iat) in seconds. Default 600 (10 min). ABCDE mints
# 60-minute tokens, so set 3600 or their tokens are rejected with LIFETIME_TOO_LONG.
PIA_SSO_MAXTOKENLIFETIMESECONDS=3600

# ── Postgres (superuser + the two app roles created on first init) ───────────────
POSTGRES_DB=pia
POSTGRES_USER=pia
POSTGRES_PASSWORD=CHANGE_ME

POSTGRES_APP_USER=pia_app
POSTGRES_APP_PASSWORD=CHANGE_ME

POSTGRES_MIGRATOR_USER=pia_migrator
POSTGRES_MIGRATOR_PASSWORD=CHANGE_ME

# ── MinIO ────────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=miniopia
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_BUCKET_ATTACHMENTS=pia-attachments
MINIO_BUCKET_QUARANTINE=pia-quarantine

# ── Grafana ──────────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ── Dev stack overrides (rootless piadev user; leave UNSET / defaults for prod) ───
# PIA_PREFIX=piadev                 # container names become piadev-postgres, piadev-nginx, …
# PIA_SHARED=/opt/piadev/shared     # certs bind-mount root (prod default: /opt/pia/shared)
# PIA_HTTP_PORT=8455                # prod uses 8453
# PIA_HTTPS_PORT=8092               # prod uses 8090
