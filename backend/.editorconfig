# EditorConfig — see https://editorconfig.org
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{kt,kts}]
indent_size = 4
max_line_length = 140

# ktlint rules
# package-name: disabled because in.gov.ir.pia requires backtick quoting of `in` (Kotlin keyword)
# which ktlint's standard rule rejects. The package is correct; the rule is overly strict here.
ktlint_standard_package-name = disabled

# Test files routinely contain long backtick function names and long assertion strings that
# cannot be meaningfully shortened. Disable max_line_length for test sources only.
[**/*Test.kt]
max_line_length = off

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
