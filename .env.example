# PIA Tracker — environment template
# Copy to .env (which is gitignored) and fill in values for your environment.
# For local development, the defaults below mostly work as-is.

# ─── Application profile ─────────────────────────────────────────────────────
PIA_PROFILE=dev                # dev | beta | prod
PIA_AUTH_MODE=dummy             # dummy | real (Keycloak in Phase 3)

# ─── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pia
POSTGRES_USER=pia
POSTGRES_PASSWORD=change-me-in-real-deployments

# Role used by Flyway migrations (more privileges than the app role)
POSTGRES_MIGRATOR_USER=pia_migrator
POSTGRES_MIGRATOR_PASSWORD=change-me-in-real-deployments

# Role used at runtime by the app (least privilege)
POSTGRES_APP_USER=pia_app
POSTGRES_APP_PASSWORD=change-me-in-real-deployments

# ─── MinIO ───────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=miniopia
MINIO_ROOT_PASSWORD=change-me-in-real-deployments
MINIO_BUCKET_ATTACHMENTS=pia-attachments
MINIO_BUCKET_QUARANTINE=pia-quarantine

# ─── ClamAV ──────────────────────────────────────────────────────────────────
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ─── JWT (used once real auth lands; placeholder for now) ────────────────────
JWT_SIGNING_KEY=change-me-32-bytes-base64-encoded
JWT_ISSUER=pia-tracker
JWT_AUDIENCE=pia-tracker-clients
JWT_TTL_SECONDS=900             # 15 min idle

# ─── Keycloak (Phase 3) ──────────────────────────────────────────────────────
KEYCLOAK_ISSUER_URL=
KEYCLOAK_CLIENT_ID=pia-tracker
KEYCLOAK_CLIENT_SECRET=

# ─── SMTP (Phase 3) ──────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@pia.tracker.localhost

# ─── Backup encryption (Phase 2+) ────────────────────────────────────────────
GPG_BACKUP_RECIPIENT=pia-backup

# ─── Observability ───────────────────────────────────────────────────────────
PROMETHEUS_RETENTION_DAYS=30
LOKI_RETENTION_DAYS=90
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-real-deployments

# ─── Misc ────────────────────────────────────────────────────────────────────
TZ=Asia/Kolkata
PIA_LOG_LEVEL=INFO              # INFO | DEBUG | WARN
PIA_BASE_URL=https://pia.local  # for absolute links in emails / notifications
