root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.{ts,tsx,js,jsx,json,css,scss,html,md,yml,yaml}]
indent_size = 2

[*.{kt,kts}]
indent_size = 4
ij_kotlin_imports_layout = *

[Makefile]
indent_style = tab

[*.sql]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
